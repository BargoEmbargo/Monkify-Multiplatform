# EditorConfig: Project Root
root = true

# ------------------------------------------------------------
# These settings affect both KtLint and Android Studio Inspector.
# Some are essential for ASI, even if KtLint already enforces them.
# ------------------------------------------------------------

# =====================================
# General Formatting Rules (All Files)
# =====================================
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# =====================================
# Kotlin-Specific Formatting Rules
# =====================================
[*.{kt,kts}]

ktlint_disabled_rules = standard:no-wildcard-imports
indent_style = space
indent_size = 4
continuation_indent_size = 4


# Disallow wildcard imports
ij_kotlin_use_wildcard_imports = false
# Enforce trailing commas
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true


# ----------------------------------------------------------------
# KtLint-specific Behavior
# ----------------------------------------------------------------
# Sets the base style for ktlint. It will be overridden by the specific rules defined above (like indent size).
ktlint_code_style = android_studio

# Don't enforce Function naming rule on @Composable functions
ktlint_function_naming_ignore_when_annotated_with = Composable

# Enforce multiline when function or class signature has more than 2 parameters
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 3
ktlint_class_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 3

# Allow same-line comments after type parameter definition (eg. val c: Int // car)
ktlint_standard_type-parameter-comment = disabled

# Suppress naming rules, as they cannot be auto-corrected by ktlintFormat
ktlint_standard_filename = disabled
ktlint_standard_backing-property-naming = disabled
ktlint_standard_class-naming = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_package-name = disabled
ktlint_standard_property-naming = disabled

# Keep max length aligned with detekt settings (detekt-config.yml)
max_line_length = 140 # 100 is default for ktlint_code_style = android_studio