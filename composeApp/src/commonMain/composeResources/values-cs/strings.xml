    <string name="app_name">Monkify</string>
    <string name="onboarding_title_1">Odemkněte svůj potenciál!</string>
    <string name="onboarding_desc_1">Konzistence je klíčem k dosažení vašich cílů. Vítejte v Monkify, vašem každodenním společníkovi na cestě k disciplinovanějšímu a úspěšnějšímu já! Pojďme začít!</string>
    <string name="onboarding_title_2">Definujte svou cestu</string>
    <string name="onboarding_desc_2">Převezměte kontrolu nad svým životem stanovením jasných, dosažitelných cílů. Monkify vám pomůže definovat cestu a bude vás motivovat, abyste své sny proměnili ve skutečnost.</string>
    <string name="onboarding_title_3">Budujte trvalé návyky</string>
    <string name="onboarding_desc_3">Úspěch není jednorázová událost; je to výsledek každodenních návyků. S Monkify si můžete vybudovat disciplínu vedoucí k celoživotnímu úspěchu. Začněte svou cestu dnes.</string>
